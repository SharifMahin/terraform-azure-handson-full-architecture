# Terraform cache
**/.terraform/*

# State files (NEVER commit)
*.tfstate
*.tfstate.*

# Plan files
*.tfplan
*.plan

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# MOST IMPORTANT - contains secrets
**/terraform.tfvars
**/*.auto.tfvars

# Azure
.azure/

# OS
.DS_Store
Thumbs.db

# VS Code
.vscode/
*.code-workspace

# Logs
*.log